# Appwrite Configuration
# Copy this file to .env.local and fill in your actual values

# Your Appwrite API endpoint (usually https://cloud.appwrite.io/v1)
VITE_APPWRITE_API_ENDPOINT=your_appwrite_endpoint_here

# Your Appwrite project ID (found in your Appwrite console)
VITE_APPWRITE_PROJECT_ID=your_project_id_here

# Your Appwrite API key (create one in your Appwrite console)
VITE_APPWRITE_API_KEY=your_api_key_here

# Your database ID (found in your Appwrite console under Databases)
VITE_APPWRITE_DATABASE_ID=your_database_id_here

# Your users collection ID (found in your Appwrite console under Collections)
VITE_APPWRITE_USERS_COLLECTION_ID=your_users_collection_id_here

# Your trips collection ID (found in your Appwrite console under Collections)
VITE_APPWRITE_TRIPS_COLLECTION_ID=your_trips_collection_id_here

# Google Gemini API Key (for AI trip generation)
# Get yours at: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Unsplash API Access Key (for trip images)
# Get yours at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

